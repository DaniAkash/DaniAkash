---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

const posts = (await getCollection("blog")).sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Group posts by year
const postsByYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = new Date(post.data.date).getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)?.push(post);
}
const years = [...postsByYear.keys()].sort((a, b) => b - a);
---

<MainLayout title="Blog" description="Articles on AI, JavaScript, React Native, and building for the web.">
  <!-- Header -->
  <header class="pb-12 pt-[120px]">
    <p class="mb-6 font-mono text-[11px] uppercase tracking-[1.65px] text-muted-foreground">
      02 // BLOG
    </p>
    <h1
      class="mb-4 font-bold leading-[1.1] tracking-[-0.03em]"
      style="font-size: clamp(36px, 5vw, 56px);"
    >
      The Blog Zone
    </h1>
    <p class="max-w-[600px] text-lg leading-relaxed text-muted-foreground">
      Where my thoughts get some air time and occasionally make sense.
    </p>
  </header>

  <!-- Timeline -->
  <div class="relative overflow-clip" id="timelineComponent">
    <!-- Vertical progress track -->
    <div class="absolute top-0 bottom-0 w-[2px] bg-foreground/10" id="progressTrack">
      <div class="absolute top-0 left-0 w-[2px] bg-primary" id="progressBar" style="height: 0;" />
    </div>

    <!-- Fade overlays -->
    <div class="pointer-events-none absolute inset-x-0 top-0 z-2 h-20 bg-gradient-to-b from-background to-transparent" />
    <div class="pointer-events-none absolute inset-x-0 bottom-0 z-2 h-20 bg-gradient-to-t from-background to-transparent" />

    {years.map((year) => {
      const yearPosts = postsByYear.get(year)!;
      return (
        <div class="timeline-item relative grid gap-0 py-12" style="grid-template-columns: 120px 30px 1fr;">
          {/* Left — sticky year */}
          <div class="pr-4">
            <div class="sticky top-[45vh] self-start text-right font-mono text-sm font-medium tracking-wide text-muted-foreground">
              {year}
            </div>
          </div>

          {/* Centre — sticky dot */}
          <div class="flex justify-center">
            <div class="sticky top-[50vh] z-1 size-[9px] self-start rounded-full bg-primary" />
          </div>

          {/* Right — posts */}
          <div class="flex flex-col pl-6">
            {yearPosts.map((post) => {
              const date = new Date(post.data.date);
              const dateDisplay = date.toLocaleDateString("en-US", {
                month: "long",
                day: "numeric",
                year: "numeric",
              });
              return (
                <a
                  href={`/posts/${post.id}/`}
                  class="group -mx-4 block border-b border-dashed border-border px-4 py-4 transition-colors last:border-b-0 hover:rounded-sm hover:bg-foreground/5"
                >
                  <div class="mb-1 font-mono text-xs tracking-wide text-muted-foreground">
                    {dateDisplay}
                  </div>
                  <h2 class="mb-1 text-[17px] font-medium leading-snug tracking-tight transition-colors group-hover:text-primary">
                    {post.data.title}
                  </h2>
                  <p class="mb-2 text-sm leading-normal text-muted-foreground line-clamp-2">
                    {post.data.subtitle}
                  </p>
                  <span class="font-mono text-[11px] tracking-wide text-primary">
                    Read article <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>

  <hr class="mt-20 border-dashed border-border" />
</MainLayout>

<style>
  /* Responsive: tablet */
  @media (max-width: 900px) {
    .timeline-item {
      grid-template-columns: 90px 24px 1fr !important;
    }
  }

  /* Responsive: mobile — hide left column */
  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 24px 1fr !important;
    }
    .timeline-item > div:first-child {
      display: none;
    }
  }
</style>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    if (window.__timelineCleanup) window.__timelineCleanup();

    var comp = document.getElementById("timelineComponent");
    var bar = document.getElementById("progressBar");
    var track = document.getElementById("progressTrack");
    if (!comp || !bar || !track) return;

    function alignProgress() {
      var circle = comp.querySelector(".sticky.rounded-full");
      if (circle) {
        var compRect = comp.getBoundingClientRect();
        var circleRect = circle.getBoundingClientRect();
        var left =
          circleRect.left + circleRect.width / 2 - compRect.left - 1;
        track.style.left = left + "px";
      }
    }
    alignProgress();

    var resizeHandler = function () {
      alignProgress();
    };
    window.addEventListener("resize", resizeHandler);

    var animId;
    function updateProgress() {
      var rect = comp.getBoundingClientRect();
      var viewportMid = window.innerHeight * 0.5;
      var fillPx = viewportMid - rect.top;
      bar.style.height =
        Math.max(0, Math.min(fillPx, rect.height)) + "px";
      animId = requestAnimationFrame(updateProgress);
    }
    animId = requestAnimationFrame(updateProgress);

    window.__timelineCleanup = function () {
      cancelAnimationFrame(animId);
      window.removeEventListener("resize", resizeHandler);
    };
  });
</script>
