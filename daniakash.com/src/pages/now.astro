---
// @ts-expect-error — Vite raw import
import rawMd from "../content/now/now.md?raw";
import MainLayout from "../layouts/MainLayout.astro";

const content = rawMd.replace(/^---[\s\S]*?---\n*/, "").trim();
---

<MainLayout title="Now">
  <div class="mx-auto max-w-[900px] pt-[120px] pb-20">
    <div class="md-editor">
      <div class="md-editor__titlebar">
        <span class="md-editor__dot md-editor__dot--red"></span>
        <span class="md-editor__dot md-editor__dot--yellow"></span>
        <span class="md-editor__dot md-editor__dot--green"></span>
        <span class="md-editor__filename">now.md</span>
        <span class="md-editor__badge">read-only</span>
      </div>
      <div class="md-editor__body">
        <pre><div class="md-editor__gutter" id="gutter"></div><code class="language-markdown" id="codeBlock">{content}</code></pre>
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  .md-editor {
    display: flex;
    flex-direction: column;
    height: 70vh;
    min-height: 500px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .md-editor__titlebar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--card);
  }

  .md-editor__dot { width: 10px; height: 10px; border-radius: 50%; }
  .md-editor__dot--red { background: #FF5F57; }
  .md-editor__dot--yellow { background: #FFBD2E; }
  .md-editor__dot--green { background: #28C840; }

  .md-editor__filename {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted-foreground);
    margin-left: 8px;
  }

  .md-editor__badge {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--primary);
    background: oklch(from var(--primary) l c h / 15%);
    padding: 1px 8px;
    border-radius: 999px;
    margin-left: auto;
  }

  .md-editor__body {
    flex: 1;
    overflow: auto;
    min-height: 0;
    position: relative;
  }

  .md-editor__body pre[class*="language-"],
  .md-editor__body pre {
    margin: 0 !important;
    border-radius: 0 !important;
    background: var(--card) !important;
    padding: 24px 24px 24px 80px !important;
    font-family: var(--font-mono) !important;
    font-size: 14px !important;
    line-height: 1.8 !important;
    tab-size: 2;
    min-height: 100%;
    position: relative;
  }

  .md-editor__gutter {
    position: absolute;
    top: 0;
    left: 0;
    width: 60px;
    padding: 24px 0;
    text-align: right;
    border-right: 1px solid var(--border);
    background: var(--card);
    user-select: none;
    z-index: 1;
    min-height: 100%;
  }

  .md-editor__gutter span {
    display: block;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.8;
    padding-right: 12px;
    color: var(--muted-foreground);
    opacity: 0.2;
  }

  /* Prism base overrides */
  .md-editor__body code[class*="language-"],
  .md-editor__body pre[class*="language-"] {
    color: var(--muted-foreground) !important;
    text-shadow: none !important;
    font-family: var(--font-mono) !important;
  }

  /* Token overrides */
  .md-editor__body .token.title .token.important {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }
  .md-editor__body .token.title .token.punctuation {
    color: var(--primary) !important;
  }
  .md-editor__body .token.bold {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }
  .md-editor__body .token.italic {
    color: var(--foreground) !important;
    font-style: italic !important;
  }
  .md-editor__body .token.url {
    color: var(--primary) !important;
  }
  .md-editor__body .token.list.punctuation {
    color: var(--primary) !important;
  }
  .md-editor__body .token.blockquote.punctuation {
    color: var(--primary) !important;
  }
  .md-editor__body .token.hr {
    color: var(--foreground) !important;
    opacity: 0.12;
  }
  .md-editor__body .token.code-snippet {
    color: var(--primary) !important;
  }
  .md-editor__body .token.punctuation {
    color: var(--muted-foreground) !important;
  }

  /* Table layout (replaces pre after Prism highlights) */
  .md-editor__table {
    width: 100%;
    border-collapse: collapse;
    background: var(--card);
  }

  .md-editor__table tr:first-child .md-editor__ln,
  .md-editor__table tr:first-child .md-editor__code {
    padding-top: 24px;
  }

  .md-editor__table tr:last-child .md-editor__ln,
  .md-editor__table tr:last-child .md-editor__code {
    padding-bottom: 24px;
  }

  .md-editor__ln {
    width: 60px;
    min-width: 60px;
    text-align: right;
    padding-right: 12px;
    vertical-align: top;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.8;
    color: var(--muted-foreground);
    opacity: 0.2;
    user-select: none;
    border-right: 1px solid var(--border);
  }

  .md-editor__code {
    padding-left: 20px;
    padding-right: 24px;
    vertical-align: top;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.8;
    color: var(--muted-foreground);
  }

  .md-editor__code code {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    background: none !important;
    padding: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Clickable links */
  .md-editor__body a.md-link {
    color: var(--primary) !important;
    text-decoration: none;
    pointer-events: auto;
    cursor: pointer;
  }
  .md-editor__body a.md-link:hover {
    text-decoration: underline;
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-markdown.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css" />
<script is:inline>
  function initNowEditor() {
    var body = document.querySelector('.md-editor__body');
    if (!body) return;

    // Skip if already initialized (table already exists)
    if (body.querySelector('.md-editor__table')) return;

    var code = body.querySelector('code');
    if (!code) return;

    // Ensure Prism is loaded before highlighting
    function runHighlight() {
      if (typeof Prism !== 'undefined') Prism.highlightAll();

      setTimeout(function() {
        var freshCode = body.querySelector('code');
        if (!freshCode) return;

        var highlightedHTML = freshCode.innerHTML;
        var lines = highlightedHTML.split('\n');

        var table = document.createElement('table');
        table.className = 'md-editor__table';
        var tbody = document.createElement('tbody');

        lines.forEach(function(lineHTML, i) {
          var tr = document.createElement('tr');

          var tdNum = document.createElement('td');
          tdNum.className = 'md-editor__ln';
          tdNum.textContent = i + 1;

          var tdCode = document.createElement('td');
          tdCode.className = 'md-editor__code';
          tdCode.innerHTML = '<code>' + (lineHTML || '&nbsp;') + '</code>';

          tr.appendChild(tdNum);
          tr.appendChild(tdCode);
          tbody.appendChild(tr);
        });

        table.appendChild(tbody);

        var pre = body.querySelector('pre');
        if (pre) pre.remove();
        body.appendChild(table);

        // Make markdown links clickable
        body.querySelectorAll('.token.url').forEach(function(token) {
          var text = token.textContent;
          var match = text.match(/\(([^)]+)\)/);
          if (match && match[1].startsWith('http')) {
            var a = document.createElement('a');
            a.href = match[1];
            a.target = '_blank';
            a.rel = 'noopener';
            a.className = 'md-link';
            while (token.firstChild) a.appendChild(token.firstChild);
            token.appendChild(a);
          }
        });
      }, 150);
    }

    if (typeof Prism !== 'undefined') {
      runHighlight();
    } else {
      // Prism not loaded yet — wait for it
      var checkInterval = setInterval(function() {
        if (typeof Prism !== 'undefined') {
          clearInterval(checkInterval);
          runHighlight();
        }
      }, 50);
      // Timeout after 3s
      setTimeout(function() { clearInterval(checkInterval); }, 3000);
    }
  }

  document.addEventListener('astro:page-load', initNowEditor);
</script>
