---
import MainLayout from "../layouts/MainLayout.astro";
// @ts-ignore — Vite raw import
import rawMd from "../content/now/now.md?raw";

const content = rawMd.replace(/^---[\s\S]*?---\n*/, "").trim();
---

<MainLayout title="Now">
  <div class="mx-auto max-w-[900px] pt-[120px] pb-20">
    <div class="now-editor">
      <!-- Title bar -->
      <div class="now-titlebar">
        <span class="now-dot" style="background:#FF5F57;"></span>
        <span class="now-dot" style="background:#FFBD2E;"></span>
        <span class="now-dot" style="background:#28C840;"></span>
        <span class="now-filename">now.md</span>
        <span class="now-badge">read-only</span>
      </div>

      <!-- Editor body -->
      <div class="now-body">
        <pre class="line-numbers"><code class="language-markdown" id="codeBlock">{content}</code></pre>
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  .now-editor {
    display: flex;
    flex-direction: column;
    height: 70vh;
    min-height: 500px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .now-titlebar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--card);
  }

  .now-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .now-filename {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted-foreground);
    margin-left: 8px;
  }

  .now-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--primary);
    background: oklch(from var(--primary) l c h / 15%);
    padding: 1px 8px;
    border-radius: 999px;
    margin-left: auto;
  }

  .now-body {
    flex: 1;
    overflow: auto;
    min-height: 0;
  }

  .now-body pre[class*="language-"] {
    margin: 0 !important;
    border-radius: 0 !important;
    background: var(--card) !important;
    font-family: var(--font-mono) !important;
    font-size: 14px !important;
    line-height: 1.8 !important;
    padding: 24px 24px 24px 80px !important;
    tab-size: 2;
    min-height: 100%;
  }

  /* Prism line-numbers plugin overrides */
  .now-body .line-numbers .line-numbers-rows {
    border-right: 1px solid var(--border) !important;
  }

  .now-body .line-numbers .line-numbers-rows > span::before {
    color: var(--muted-foreground) !important;
    opacity: 0.4;
  }

  .now-body .line-numbers .line-numbers-rows {
    left: 0 !important;
    width: 60px !important;
    padding: 24px 12px 24px 0 !important;
    text-align: right;
  }

  /* Prism base text */
  .now-body code[class*="language-"],
  .now-body pre[class*="language-"] {
    color: var(--muted-foreground) !important;
    text-shadow: none !important;
  }

  /* Token overrides */
  .now-body .token.title .token.important {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }

  .now-body .token.title .token.punctuation {
    color: var(--primary) !important;
  }

  .now-body .token.bold {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }

  .now-body .token.italic {
    color: var(--foreground) !important;
    font-style: italic !important;
  }

  .now-body .token.url {
    color: var(--primary) !important;
  }

  .now-body .token.list.punctuation {
    color: var(--primary) !important;
  }

  .now-body .token.blockquote.punctuation {
    color: var(--primary) !important;
  }

  .now-body .token.hr {
    color: var(--foreground) !important;
    opacity: 0.12;
  }

  .now-body .token.code-snippet {
    color: var(--primary) !important;
  }

  /* Clickable links */
  #codeBlock a.md-link {
    color: inherit !important;
    text-decoration: none;
    cursor: pointer;
    pointer-events: auto;
  }

  #codeBlock a.md-link:hover {
    text-decoration: underline;
  }
</style>

<script is:inline>
  (function() {
    function loadCSS(href, id) {
      if (document.getElementById(id)) return;
      var link = document.createElement('link');
      link.id = id;
      link.rel = 'stylesheet';
      link.href = href;
      document.head.appendChild(link);
    }

    function loadScript(src, cb) {
      var s = document.createElement('script');
      s.src = src;
      s.onload = cb;
      document.head.appendChild(s);
    }

    function highlight() {
      if (typeof Prism === 'undefined') return;
      Prism.highlightAll();

      setTimeout(function() {
        document.querySelectorAll('#codeBlock .token.url').forEach(function(token) {
          var text = token.textContent;
          var match = text.match(/\(([^)]+)\)/);
          if (match && match[1].startsWith('http')) {
            var a = document.createElement('a');
            a.href = match[1];
            a.target = '_blank';
            a.rel = 'noopener';
            a.className = 'md-link';
            while (token.firstChild) a.appendChild(token.firstChild);
            token.appendChild(a);
          }
        });
      }, 100);
    }

    // Load Prism CSS + line-numbers CSS
    loadCSS('https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css', 'prism-css');
    loadCSS('https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/line-numbers/prism-line-numbers.min.css', 'prism-ln-css');

    if (typeof Prism !== 'undefined') {
      highlight();
    } else {
      loadScript('https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js', function() {
        loadScript('https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-markdown.min.js', function() {
          loadScript('https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/line-numbers/prism-line-numbers.min.js', highlight);
        });
      });
    }
  })();
</script>
