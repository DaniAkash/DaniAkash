---
import MainLayout from "../layouts/MainLayout.astro";
// @ts-ignore — Vite raw import
import rawMd from "../content/now/now.md?raw";

const content = rawMd.replace(/^---[\s\S]*?---\n*/, "").trim();
const lines = content.split("\n");
---

<MainLayout title="Now">
  <div class="mx-auto max-w-[900px] pt-[120px] pb-20">
    <div class="now-editor">
      <!-- Title bar -->
      <div class="now-titlebar">
        <span class="now-dot" style="background:#FF5F57;"></span>
        <span class="now-dot" style="background:#FFBD2E;"></span>
        <span class="now-dot" style="background:#28C840;"></span>
        <span class="now-filename">now.md</span>
        <span class="now-badge">read-only</span>
      </div>

      <!-- Editor body — each line is a row -->
      <div class="now-body">
        <table class="now-table" id="codeTable">
          <tbody>
            {lines.map((line, i) => (
              <tr class="now-row">
                <td class="now-ln">{i + 1}</td>
                <td class="now-code"><code>{line || "\u00A0"}</code></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  .now-editor {
    display: flex;
    flex-direction: column;
    height: 70vh;
    min-height: 500px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .now-titlebar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--card);
  }

  .now-dot { width: 10px; height: 10px; border-radius: 50%; }

  .now-filename {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted-foreground);
    margin-left: 8px;
  }

  .now-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--primary);
    background: oklch(from var(--primary) l c h / 15%);
    padding: 1px 8px;
    border-radius: 999px;
    margin-left: auto;
  }

  .now-body {
    flex: 1;
    overflow: auto;
    min-height: 0;
    background: var(--card);
  }

  .now-table {
    width: 100%;
    border-collapse: collapse;
    padding: 16px 0;
  }

  .now-row:first-child .now-ln,
  .now-row:first-child .now-code {
    padding-top: 24px;
  }

  .now-row:last-child .now-ln,
  .now-row:last-child .now-code {
    padding-bottom: 24px;
  }

  .now-ln {
    width: 60px;
    min-width: 60px;
    text-align: right;
    padding-right: 16px;
    padding-left: 8px;
    vertical-align: top;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.8;
    color: var(--muted-foreground);
    opacity: 0.25;
    user-select: none;
    border-right: 1px solid var(--border);
  }

  .now-code {
    padding-left: 20px;
    padding-right: 24px;
    vertical-align: top;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.8;
    color: var(--muted-foreground);
    word-break: break-word;
  }

  .now-code code {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    background: none;
    padding: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
