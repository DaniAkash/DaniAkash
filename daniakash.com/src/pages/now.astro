---
import MainLayout from "../layouts/MainLayout.astro";
// @ts-ignore — Vite raw import
import rawMd from "../content/now/now.md?raw";

// Strip frontmatter
const content = rawMd.replace(/^---[\s\S]*?---\n*/, "").trim();
const lineCount = content.split("\n").length;
---

<MainLayout title="Now">
  <div class="mx-auto max-w-[900px] pt-[120px] pb-20">
    <!-- Markdown Editor Window -->
    <div class="flex h-[70vh] min-h-[500px] flex-col overflow-hidden rounded-xl border border-border bg-card/50">

      <!-- Title bar -->
      <div class="flex items-center gap-2 border-b border-border bg-card px-4 py-2">
        <span class="size-[10px] rounded-full bg-[#FF5F57]"></span>
        <span class="size-[10px] rounded-full bg-[#FFBD2E]"></span>
        <span class="size-[10px] rounded-full bg-[#28C840]"></span>
        <span class="ml-2 font-mono text-xs text-muted-foreground">now.md</span>
        <span class="ml-auto rounded-full bg-primary/15 px-2 py-[1px] font-mono text-[10px] text-primary">
          read-only
        </span>
      </div>

      <!-- Editor body — single scroll container -->
      <div class="relative flex-1 overflow-auto">
        <!-- Gutter (absolute, inside pre for scroll sync) -->
        <pre class="relative m-0 min-h-full border-0 bg-transparent p-0" style="background: transparent !important;"><div class="absolute top-0 left-0 z-1 min-h-full w-[60px] select-none border-r border-border bg-card/50 py-6 text-right" id="gutter">{Array.from({ length: lineCount }, (_, i) => (
              <span class="block pr-3 font-mono text-[14px] leading-[1.8] text-foreground/10">
                {i + 1}
              </span>
            ))}</div><code class="block py-6 pr-6 pl-[80px] font-mono text-[14px] leading-[1.8] text-muted-foreground" id="codeBlock">{content}</code></pre>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  pre, pre code {
    background: transparent !important;
    margin: 0;
    border: 0;
    border-radius: 0;
    tab-size: 2;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  /* Prism token overrides */
  :global(.token.title .token.important) {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }
  :global(.token.title .token.punctuation) {
    color: var(--primary) !important;
  }
  :global(.token.bold) {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }
  :global(.token.italic) {
    color: var(--foreground) !important;
    font-style: italic !important;
  }
  :global(.token.url) {
    color: var(--primary) !important;
  }
  :global(.token.list.punctuation) {
    color: var(--primary) !important;
  }
  :global(.token.blockquote.punctuation) {
    color: var(--primary) !important;
  }
  :global(.token.hr) {
    color: var(--foreground) !important;
    opacity: 0.1;
  }
  :global(.token.code-snippet) {
    color: var(--primary) !important;
  }
  :global(.token.punctuation) {
    color: var(--muted-foreground) !important;
  }

  /* Clickable links inside code */
  :global(#codeBlock a.md-link) {
    color: inherit !important;
    text-decoration: none;
    cursor: pointer;
  }
  :global(#codeBlock a.md-link:hover) {
    text-decoration: underline;
  }
</style>

<script is:inline>
  (function() {
    if (document.getElementById('prism-css')) return;

    var css = document.createElement('link');
    css.id = 'prism-css';
    css.rel = 'stylesheet';
    css.href = 'https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css';
    document.head.appendChild(css);

    var core = document.createElement('script');
    core.src = 'https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js';
    core.onload = function() {
      var md = document.createElement('script');
      md.src = 'https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-markdown.min.js';
      md.onload = function() {
        if (typeof Prism !== 'undefined') {
          Prism.highlightAll();

          // Make markdown links clickable
          setTimeout(function() {
            document.querySelectorAll('#codeBlock .token.url').forEach(function(token) {
              var text = token.textContent;
              var match = text.match(/\(([^)]+)\)/);
              if (match && match[1].startsWith('http')) {
                var a = document.createElement('a');
                a.href = match[1];
                a.target = '_blank';
                a.rel = 'noopener';
                a.className = 'md-link';
                while (token.firstChild) a.appendChild(token.firstChild);
                token.appendChild(a);
              }
            });
          }, 100);
        }
      };
      document.head.appendChild(md);
    };
    document.head.appendChild(core);
  })();
</script>
