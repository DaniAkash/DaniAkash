---
import MainLayout from "../layouts/MainLayout.astro";
// @ts-ignore — Vite raw import
import rawMd from "../content/now/now.md?raw";

// Strip frontmatter
const content = rawMd.replace(/^---[\s\S]*?---\n*/, "").trim();
const lineCount = content.split("\n").length;
---

<MainLayout title="Now">
  <div class="mx-auto max-w-[900px] pt-[120px] pb-20">
    <div class="now-editor">
      <!-- Title bar -->
      <div class="now-titlebar">
        <span class="now-dot" style="background:#FF5F57;"></span>
        <span class="now-dot" style="background:#FFBD2E;"></span>
        <span class="now-dot" style="background:#28C840;"></span>
        <span class="now-filename">now.md</span>
        <span class="now-badge">read-only</span>
      </div>

      <!-- Editor body -->
      <div class="now-body">
        <pre class="now-pre"><div class="now-gutter" id="gutter">{Array.from({ length: lineCount }, (_, i) => (
          <span>{i + 1}</span>
        ))}</div><code class="language-markdown" id="codeBlock">{content}</code></pre>
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  .now-editor {
    display: flex;
    flex-direction: column;
    height: 70vh;
    min-height: 500px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .now-titlebar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--card);
  }

  .now-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .now-filename {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted-foreground);
    margin-left: 8px;
  }

  .now-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--primary);
    background: oklch(from var(--primary) l c h / 15%);
    padding: 1px 8px;
    border-radius: 999px;
    margin-left: auto;
  }

  .now-body {
    flex: 1;
    overflow: auto;
    min-height: 0;
    position: relative;
  }

  .now-pre {
    margin: 0 !important;
    border-radius: 0 !important;
    background: var(--card) !important;
    padding: 24px 24px 24px 80px !important;
    font-family: var(--font-mono) !important;
    font-size: 14px !important;
    line-height: 1.8 !important;
    tab-size: 2;
    min-height: 100%;
    position: relative;
    overflow-x: auto;
    color: var(--muted-foreground) !important;
  }

  .now-gutter {
    position: absolute;
    top: 0;
    left: 0;
    width: 60px;
    padding: 24px 0;
    text-align: right;
    border-right: 1px solid var(--border);
    background: var(--card);
    user-select: none;
    z-index: 1;
    min-height: 100%;
  }

  .now-gutter span {
    display: block;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.8;
    padding-right: 12px;
    color: var(--muted-foreground);
    opacity: 0.2;
  }

  /* Prism overrides */
  .now-pre code[class*="language-"],
  .now-pre pre[class*="language-"] {
    color: var(--muted-foreground) !important;
    text-shadow: none !important;
    font-family: var(--font-mono) !important;
    background: transparent !important;
  }

  .now-pre .token.title .token.important {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }

  .now-pre .token.title .token.punctuation {
    color: var(--primary) !important;
  }

  .now-pre .token.bold {
    color: var(--foreground) !important;
    font-weight: 600 !important;
  }

  .now-pre .token.italic {
    color: var(--foreground) !important;
    font-style: italic !important;
  }

  .now-pre .token.url {
    color: var(--primary) !important;
  }

  .now-pre .token.list.punctuation {
    color: var(--primary) !important;
  }

  .now-pre .token.blockquote.punctuation {
    color: var(--primary) !important;
  }

  .now-pre .token.hr {
    color: var(--foreground) !important;
    opacity: 0.12;
  }

  .now-pre .token.code-snippet {
    color: var(--primary) !important;
  }

  /* Clickable links */
  #codeBlock a.md-link {
    color: inherit !important;
    text-decoration: none;
    cursor: pointer;
    pointer-events: auto;
  }

  #codeBlock a.md-link:hover {
    text-decoration: underline;
  }
</style>

<script is:inline>
  (function() {
    // Load Prism CSS
    if (!document.getElementById('prism-css')) {
      var css = document.createElement('link');
      css.id = 'prism-css';
      css.rel = 'stylesheet';
      css.href = 'https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css';
      document.head.appendChild(css);
    }

    // Load Prism JS
    function loadScript(src, cb) {
      var s = document.createElement('script');
      s.src = src;
      s.onload = cb;
      document.head.appendChild(s);
    }

    function highlight() {
      if (typeof Prism === 'undefined') return;
      Prism.highlightAll();

      // Make links clickable after highlighting
      setTimeout(function() {
        document.querySelectorAll('#codeBlock .token.url').forEach(function(token) {
          var text = token.textContent;
          var match = text.match(/\(([^)]+)\)/);
          if (match && match[1].startsWith('http')) {
            var a = document.createElement('a');
            a.href = match[1];
            a.target = '_blank';
            a.rel = 'noopener';
            a.className = 'md-link';
            while (token.firstChild) a.appendChild(token.firstChild);
            token.appendChild(a);
          }
        });
      }, 100);
    }

    if (typeof Prism !== 'undefined') {
      highlight();
    } else {
      loadScript('https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js', function() {
        loadScript('https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-markdown.min.js', highlight);
      });
    }
  })();
</script>
