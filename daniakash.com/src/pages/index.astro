---
import { getCollection } from "astro:content";
import AmbientCanvas from "../components/AmbientCanvas";
import BlueskyIcon from "../components/icons/BlueskyIcon.astro";
import GithubIcon from "../components/icons/GithubIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import LinkedinIcon from "../components/icons/LinkedinIcon.astro";
import MailIcon from "../components/icons/MailIcon.astro";
import TwitterIcon from "../components/icons/TwitterIcon.astro";
import { ASSET_PREFIX } from "../constants/asset-prefix";
import MainLayout from "../layouts/MainLayout.astro";

const posts = (await getCollection("blog"))
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 7);

const career = await getCollection("career");
const experience = career[0]?.data?.items ?? [];

const social = await getCollection("social");
const socialData = social[0]?.data;

const connectLinks = [
  {
    platform: "GitHub",
    handle: `@DaniAkash`,
    href: socialData?.github ?? "https://github.com/DaniAkash",
  },
  {
    platform: "X / Twitter",
    handle: `@dani_akash_`,
    href: socialData?.twitter ?? "https://x.com/dani_akash_",
  },
  {
    platform: "Bluesky",
    handle: `@daniakash.com`,
    href: socialData?.bluesky ?? "https://bsky.app/profile/daniakash.com",
  },
  {
    platform: "LinkedIn",
    handle: "Dani Akash",
    href: socialData?.linkedIn ?? "https://www.linkedin.com/in/daniakash",
  },
  {
    platform: "Instagram",
    handle: `@dani_akash_`,
    href: socialData?.instagram ?? "https://www.instagram.com/dani_akash_",
  },
  {
    platform: "Email",
    handle: socialData?.email ?? "hello@daniakash.com",
    href: `mailto:${socialData?.email ?? "hello@daniakash.com"}`,
  },
];

const heroImages = [
  { src: `${ASSET_PREFIX}/image-1.jpg`, alt: "Dani Akash" },
  { src: `${ASSET_PREFIX}/image-2.jpg`, alt: "Dani Akash" },
  { src: `${ASSET_PREFIX}/image-3.jpg`, alt: "Dani Akash" },
  { src: `${ASSET_PREFIX}/image-4.jpg`, alt: "Dani Akash" },
  { src: `${ASSET_PREFIX}/image-5.jpg`, alt: "Dani Akash" },
];
---

<MainLayout title="">
  <!-- Ambient Background -->
  <AmbientCanvas client:visible />

  <!-- System Labels -->
  <div class="pointer-events-none fixed bottom-6 left-6 z-50 hidden font-mono text-[10px] uppercase tracking-widest text-muted-foreground md:block">
    CHENNAI, IN &middot; UTC+5:30
  </div>
  <div class="pointer-events-none fixed bottom-6 right-6 z-50 hidden font-mono text-[10px] uppercase tracking-widest text-muted-foreground md:block">
    V4.0 // 2026
  </div>

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen overflow-hidden pb-80 pt-32">
    <div>
      <p
        class="mb-6 font-mono text-[11px] uppercase tracking-[0.15em] text-muted-foreground"
      >
        SYS.ROLE // AI_ENGINEER &middot; BUILDER &middot; SPEAKER
      </p>
      <h1
        class="mb-6 font-bold leading-[1.05] tracking-[-0.03em]"
        style="font-size: clamp(3rem, 8vw, 6rem);"
      >
        Dani Akash
      </h1>
      <p class="mb-12 max-w-2xl font-light leading-[1.4] text-muted-foreground" style="font-size: clamp(1.125rem, 2.5vw, 1.75rem);">
        A simple developer building AI agents for humans. I build what I need,
        open source what I can, and keep shipping every day.
      </p>

      <!-- Social icons -->
      <div class="mb-12 flex flex-wrap gap-4">
        {
          [
            { href: socialData?.github, Icon: GithubIcon, label: "GitHub" },
            { href: socialData?.twitter, Icon: TwitterIcon, label: "X" },
            { href: socialData?.bluesky, Icon: BlueskyIcon, label: "Bluesky" },
            { href: socialData?.linkedIn, Icon: LinkedinIcon, label: "LinkedIn" },
            { href: socialData?.instagram, Icon: InstagramIcon, label: "Instagram" },
            { href: `mailto:${socialData?.email}`, Icon: MailIcon, label: "Email" },
          ].map(({ href, Icon, label }) => (
            <a
              href={href}
              aria-label={label}
              title={label}
              target={href?.startsWith("mailto") ? undefined : "_blank"}
              rel={href?.startsWith("mailto") ? undefined : "noopener"}
              class="flex size-11 items-center justify-center rounded-full border border-border bg-foreground/5 text-muted-foreground transition-all hover:-translate-y-0.5 hover:border-primary hover:bg-primary/15 hover:text-primary"
            >
              <Icon class="size-5" />
            </a>
          ))
        }
      </div>

      <!-- Status line -->
      <div class="flex items-center gap-2 font-mono text-xs text-muted-foreground">
        <span class="size-1.5 animate-pulse rounded-full bg-primary" />
        Building BrowserOS — an AI-powered browser for agents
      </div>
    </div>

    <!-- Photo gallery — anchored to bottom of hero -->
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 flex h-96 items-end justify-center overflow-hidden"
    >
      <div class="pointer-events-auto flex items-start gap-4">
        {
          heroImages.map((img, i) => {
            const sizes = [
              "w-60 h-80 mt-16",
              "w-[17rem] h-[22rem] mt-8",
              "w-72 h-96 mt-0",
              "w-[17rem] h-[22rem] mt-8",
              "w-60 h-80 mt-16",
            ];
            const hideClasses = [
              "hidden lg:block",
              "hidden md:block",
              "",
              "hidden md:block",
              "hidden lg:block",
            ];
            return (
              <div
                class:list={[
                  "flex-shrink-0 overflow-hidden rounded-3xl shadow-lg shadow-black/25 transition-transform duration-500 hover:-translate-y-3 hover:scale-[1.02]",
                  sizes[i],
                  hideClasses[i],
                ]}
              >
                <img
                  src={img.src}
                  alt={img.alt}
                  loading="lazy"
                  class="size-full object-cover"
                />
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <hr class="border-dashed border-border" />

  <!-- ═══ 01 BLOG + WORK (two-column) ═══ -->
  <section class="py-20" id="work">
    <div class="grid items-start gap-12 lg:grid-cols-2">
      <!-- Left: Blog -->
      <div>
        <div class="mb-12 flex items-baseline gap-4">
          <span class="font-mono text-5xl font-light text-foreground/10">01</span>
          <span class="font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground">Blog</span>
        </div>
        <div class="flex flex-col">
          {
            posts.map((post) => {
              const date = new Date(post.data.date);
              const formatted = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, "0")}.${String(date.getDate()).padStart(2, "0")}`;
              return (
                <a
                  href={`/posts/${post.id}/`}
                  class="group -mx-4 flex items-baseline gap-6 border-b border-dashed border-border px-4 py-3 transition-colors last:border-b-0 hover:bg-foreground/5"
                >
                  <span class="shrink-0 font-mono text-xs text-muted-foreground">
                    {formatted}
                  </span>
                  <span class="text-[17px] font-medium leading-snug transition-colors group-hover:text-primary">
                    {post.data.title}
                  </span>
                  <span class="ml-auto shrink-0 font-mono text-sm text-muted-foreground transition-transform group-hover:translate-x-1">
                    →
                  </span>
                </a>
              );
            })
          }
        </div>
        <a href="/blog/" class="mt-6 inline-flex font-mono text-sm text-primary hover:text-primary/80">
          View all posts →
        </a>
      </div>

      <!-- Right: Work -->
      <div>
        <div class="rounded-xl border border-border p-6">
          <div class="mb-6 flex items-center gap-2 font-mono text-sm font-medium">
            <span>💼</span> Work
          </div>
          <div class="flex flex-col">
            {
              experience.map((job) => (
                <div class="flex items-center gap-4 border-b border-dashed border-border py-3 last:border-b-0">
                  <div class="flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-full border border-border bg-foreground/5">
                    <img
                      src={`${ASSET_PREFIX}/${job.logo}`}
                      alt={job.company}
                      class="size-7 object-contain"
                    />
                  </div>
                  <div class="flex min-w-0 flex-1 flex-col gap-0.5">
                    <span class="font-semibold">{job.company}</span>
                    <span class="text-sm text-muted-foreground">{job.role}</span>
                  </div>
                  <span class="shrink-0 font-mono text-xs text-muted-foreground">
                    {job.startDate} — {job.endDate}
                  </span>
                </div>
              ))
            }
          </div>
          <a
            href="/resume/"
            class="mt-4 block rounded-lg border border-border py-3 text-center font-mono text-sm text-muted-foreground transition-all hover:border-border hover:bg-foreground/5 hover:text-foreground"
          >
            Resume
          </a>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-dashed border-border" />

  <!-- ═══ 02 SPEAKING ═══ -->
  <section class="py-20" id="speaking">
    <div class="mb-12 flex items-baseline gap-4">
      <span class="font-mono text-5xl font-light text-foreground/10">02</span>
      <span class="font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground">Speaking</span>
    </div>
    <p class="mb-6 max-w-2xl text-lg leading-relaxed text-muted-foreground">
      I regularly speak at community meetups and conferences about AI,
      JavaScript, React Native, and the web. I've given 25+ talks since 2017
      across events like React Nexus, JSLovers, Thoughtworks Geeknight, React
      Bangalore, and more.
    </p>
    <a href="/speaking/" class="inline-flex font-mono text-sm text-primary hover:text-primary/80">
      View all talks →
    </a>
  </section>

  <hr class="border-dashed border-border" />

  <!-- ═══ 03 CONNECT ═══ -->
  <section class="py-20" id="connect">
    <div class="mb-12 flex items-baseline gap-4">
      <span class="font-mono text-5xl font-light text-foreground/10">03</span>
      <span class="font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground">Connect</span>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        connectLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("mailto") ? undefined : "_blank"}
            rel={link.href.startsWith("mailto") ? undefined : "noopener"}
            class="flex flex-col gap-1 rounded-xl border border-border p-6 transition-all hover:-translate-y-0.5 hover:border-primary hover:bg-foreground/5"
          >
            <span class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
              {link.platform}
            </span>
            <span class="font-medium">{link.handle}</span>
          </a>
        ))
      }
    </div>
  </section>

  <hr class="border-dashed border-border" />

  <!-- ═══ NEWSLETTER ═══ -->
  <section class="py-20">
    <div class="rounded-xl border border-border bg-card p-12 text-center">
      <h2 class="mb-2 text-2xl font-semibold">Stay in the loop</h2>
      <p class="mb-6 text-muted-foreground">
        Thoughts delivered straight to your inbox. Zero spam, I promise.
      </p>
      <form class="mx-auto flex max-w-md gap-2" action="#" method="POST">
        <input
          type="email"
          placeholder="user@domain.net"
          required
          aria-label="Email address"
          class="h-12 flex-1 rounded-full border border-border bg-foreground/5 px-6 font-mono text-sm text-foreground outline-none transition-colors placeholder:text-muted-foreground focus:border-primary"
        />
        <button
          type="submit"
          class="h-12 rounded-full bg-primary px-6 font-mono text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80"
        >
          SUBSCRIBE
        </button>
      </form>
    </div>
  </section>
</MainLayout>
