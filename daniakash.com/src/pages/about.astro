---
import { getCollection, render } from "astro:content";
import BlueskyIcon from "../components/icons/BlueskyIcon.astro";
import GithubIcon from "../components/icons/GithubIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import LinkedinIcon from "../components/icons/LinkedinIcon.astro";
import MailDarkIcon from "../components/icons/MailDarkIcon.astro";
import TwitterIcon from "../components/icons/TwitterIcon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import Globe from "../components/Globe.tsx";

const about = (await getCollection("about"))[0]!;
const { Content } = await render(about);
const social = (await getCollection("social"))[0]!;
---

<MainLayout title="About" description="About Dani Akash — AI Engineer, Builder, Speaker. Based in Chennai, India.">
  <main class="about-page">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="about-grid">

        <!-- Left: Content -->
        <div class="about-content">
          <p class="mb-6 font-mono text-[11px] uppercase tracking-[0.15em] text-muted-foreground">
            01 // ABOUT
          </p>
          <h1
            class="mb-12 font-bold leading-[1.1] tracking-[-0.03em]"
            style="font-size: clamp(36px, 5vw, 56px);"
          >
            I'm Dani Akash
          </h1>

          <div class="about-body">
            <Content />
          </div>

          <div class="about-section">
            <div class="about-subtitle">SYS.CONNECT // UPLINKS</div>
            <div class="about-connect">
              <a href={social.data.bluesky} class="connect-link" target="_blank" rel="noopener">
                <BlueskyIcon /><span class="ml-4">Follow on Bluesky</span>
              </a>
              <a href={social.data.twitter} class="connect-link" target="_blank" rel="noopener">
                <TwitterIcon /><span class="ml-4">Follow on X</span>
              </a>
              <a href={social.data.instagram} class="connect-link" target="_blank" rel="noopener">
                <InstagramIcon /><span class="ml-4">Follow on Instagram</span>
              </a>
              <a href={social.data.github} class="connect-link" target="_blank" rel="noopener">
                <GithubIcon /><span class="ml-4">Follow on GitHub</span>
              </a>
              <a href={social.data.linkedIn} class="connect-link" target="_blank" rel="noopener">
                <LinkedinIcon /><span class="ml-4">Follow on LinkedIn</span>
              </a>
              <a href={`mailto:${social.data.email}`} class="connect-link" rel="noopener">
                <MailDarkIcon /><span class="ml-4">{social.data.email}</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Globe + Spotlight (sticky) -->
        <div class="about-viz">
          <Globe client:visible />
        </div>

      </div>
    </div>
  </main>
</MainLayout>

<style>
  .about-page {
    padding-top: 100px;
    min-height: 100vh;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Left column — scrolls naturally */
  .about-content {
    padding: 80px 0;
  }

  /* About body — prose from <Content /> */
  .about-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about-body :global(p) {
    color: hsl(var(--muted-foreground));
    font-size: 16px;
    line-height: 1.75;
  }

  .about-body :global(a) {
    color: hsl(var(--primary));
    text-decoration: none;
    border-bottom: 1px dashed hsl(var(--primary));
  }

  .about-body :global(a:hover) {
    color: hsl(var(--primary));
    border-bottom-style: solid;
  }

  /* Subheadings from Content get divider treatment */
  .about-body :global(h2),
  .about-body :global(h3),
  .about-body :global(h4) {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    color: hsl(var(--muted-foreground));
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 48px;
    margin-bottom: 24px;
    padding-bottom: 8px;
    border-bottom: 1px dashed hsl(var(--border));
    font-weight: 400;
  }

  /* Subsection dividers */
  .about-section {
    margin-top: 48px;
  }

  .about-subtitle {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    color: hsl(var(--muted-foreground));
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 24px;
    padding-bottom: 8px;
    border-bottom: 1px dashed hsl(var(--border));
  }

  /* Connect links */
  .about-connect {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .connect-link {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 13px;
    color: hsl(var(--muted-foreground));
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .connect-link:hover {
    color: hsl(var(--primary));
  }

  /* Right column — sticky globe */
  .about-viz {
    position: sticky;
    top: 80px;
    height: calc(100vh - 100px);
  }

  /* Globe wrap */
  .about-viz :global(.globe-wrap) {
    flex: 1;
    min-height: 0;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
    border: 1px solid #1e1e2a;
    border-bottom: none;
    position: relative;
  }

  :global(html:not(.dark)) .about-viz :global(.globe-wrap) {
    border-color: #d8d8d0;
  }

  /* Spotlight panel */
  .about-viz :global(.spotlight) {
    border: 1px solid #1e1e2a;
    border-radius: 0 0 16px 16px;
    padding: 16px 24px;
    background: rgba(255, 255, 255, 0.025);
    cursor: pointer;
    transition: all 0.2s ease;
    min-height: 110px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  :global(html:not(.dark)) .about-viz :global(.spotlight) {
    border-color: #d8d8d0;
    background: rgba(0, 0, 0, 0.025);
  }

  .about-viz :global(.spotlight:hover) {
    background: rgba(255, 255, 255, 0.05);
  }

  :global(html:not(.dark)) .about-viz :global(.spotlight:hover) {
    background: rgba(0, 0, 0, 0.05);
  }

  .about-viz :global(.spotlight-btn) {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 14px;
    color: hsl(var(--muted-foreground));
    background: none;
    border: 1px solid #1e1e2a;
    border-radius: 8px;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  :global(html:not(.dark)) .about-viz :global(.spotlight-btn) {
    border-color: #d8d8d0;
  }

  .about-viz :global(.spotlight-btn:hover) {
    color: hsl(var(--primary));
    border-color: hsl(var(--primary));
    background: hsl(var(--primary) / 0.15);
  }

  .about-viz :global(.spotlight-input) {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    color: hsl(var(--foreground));
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid #1e1e2a;
    border-radius: 4px;
    width: 32px;
    height: 24px;
    text-align: center;
    padding: 0;
    outline: none;
    -moz-appearance: textfield;
  }

  :global(html:not(.dark)) .about-viz :global(.spotlight-input) {
    background: rgba(0, 0, 0, 0.05);
    border-color: #d8d8d0;
  }

  .about-viz :global(.spotlight-input:focus) {
    border-color: hsl(var(--primary));
  }

  .about-viz :global(.spotlight-input::-webkit-inner-spin-button),
  .about-viz :global(.spotlight-input::-webkit-outer-spin-button) {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Tablet */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-content {
      padding-top: 24px;
    }

    .about-viz {
      position: relative;
      top: 0;
      height: 400px;
      order: -1;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .about-viz {
      height: 300px;
    }
  }
</style>
