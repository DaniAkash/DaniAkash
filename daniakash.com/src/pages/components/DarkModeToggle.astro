---
import { fade } from "astro:transitions";
import { TRANSITION_NAMES } from "../../constants/transition-names";
---

<button
  aria-label="dark mode toggle"
  id="dev-theme-mode-toggle"
  class="group border border-[color:var(--page-border)] bg-[linear-gradient(135deg,color-mix(in_srgb,var(--page-accent-primary)_14%,var(--page-panel)),color-mix(in_srgb,var(--page-accent-secondary)_12%,var(--page-panel)))] px-3 py-2 transition hover:border-[color:var(--page-strong-border)]"
  transition:name={TRANSITION_NAMES.darkModeToggle}
  transition:animate={fade({ duration: 500 })}
>
  <svg
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-6 w-6 fill-ctp-crust stroke-ctp-overlay1 transition group-hover:fill-ctp-mauve group-hover:stroke-ctp-blue dark:hidden"
    ><path
      d="M8 12.25A4.25 4.25 0 0 1 12.25 8v0a4.25 4.25 0 0 1 4.25 4.25v0a4.25 4.25 0 0 1-4.25 4.25v0A4.25 4.25 0 0 1 8 12.25v0Z"
    ></path><path
      d="M12.25 3v1.5M21.5 12.25H20M18.791 18.791l-1.06-1.06M18.791 5.709l-1.06 1.06M12.25 20v1.5M4.5 12.25H3M6.77 6.77 5.709 5.709M6.77 17.73l-1.061 1.061"
      fill="none"></path>
  </svg><svg
    viewBox="0 0 24 24"
    class="hidden h-6 w-6 fill-ctp-text stroke-ctp-lavender transition group-hover:fill-ctp-rosewater group-hover:stroke-ctp-sky dark:block"
    ><path
      d="M17.25 16.22a6.937 6.937 0 0 1-9.47-9.47 7.451 7.451 0 1 0 9.47 9.47ZM12.75 7C17 7 17 2.75 17 2.75S17 7 21.25 7C17 7 17 11.25 17 11.25S17 7 12.75 7Z"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</button>

<script type="text/javascript" data-astro-rerun is:inline>
  (() => {
    const $html = document.querySelector("html");
    const themeKey = "@page/theme";

    const applyTheme = (theme) => {
      $html.classList.remove("dark", "latte", "mocha");

      if (theme === "dark") {
        $html.classList.add("dark", "mocha");
      } else {
        $html.classList.add("latte");
      }
    };

    const theme = (() => {
      if (
        typeof localStorage !== "undefined" &&
        localStorage.getItem(themeKey)
      ) {
        return localStorage.getItem(themeKey);
      }
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        return "dark";
      }
      return "light";
    })();

    applyTheme(theme);

    window.localStorage.setItem(themeKey, theme);

    const handleToggleClick = () => {
      const isDark = $html.classList.contains("dark");
      const nextTheme = isDark ? "light" : "dark";
      applyTheme(nextTheme);
      localStorage.setItem(themeKey, nextTheme);
    };

    document
      .getElementById("dev-theme-mode-toggle")
      .addEventListener("click", handleToggleClick);
  })();
</script>
