---
import "../styles/global.css";
import Footer from "../pages/components/Footer.astro";
import ContentArea from "./ContentArea.astro";
import Header from "./Header.astro";
import { ClientRouter } from "astro:transitions";
import { Seo } from "astro-seo-meta";
import { getOGImage } from "../utils/getOGImage";
import { ASSET_PREFIX } from "../constants/asset-prefix";

interface Props {
  isHomePage?: boolean;
  title: string;
  description?: string;
  keywords?: string[];
  canonical?: string;
  image?: string;
}

const {
  isHomePage = false,
  title = "",
  keywords,
  description,
  canonical,
  image,
} = Astro.props;

let fallbackImage: string = "";
if (!image) {
  const image = `/og/general/${encodeURI(Astro.url.pathname.split("/").join("-"))}.png`;
  await getOGImage({
    title: title || "Dani Akash",
    description:
      description ||
      "Empowering ideas and inspiring creativity – Discover more at daniakash.com",
    path: image,
    cover: `${ASSET_PREFIX}/image-3.jpg`,
  });
  fallbackImage = image;
}
const ogImage = image || fallbackImage;
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="apple-touch-icon" sizes="57x57" href="/apple-icon-57x57.png" />
    <link rel="apple-touch-icon" sizes="60x60" href="/apple-icon-60x60.png" />
    <link rel="apple-touch-icon" sizes="72x72" href="/apple-icon-72x72.png" />
    <link rel="apple-touch-icon" sizes="76x76" href="/apple-icon-76x76.png" />
    <link
      rel="apple-touch-icon"
      sizes="114x114"
      href="/apple-icon-114x114.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href="/apple-icon-120x120.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="144x144"
      href="/apple-icon-144x144.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href="/apple-icon-152x152.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-icon-180x180.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/android-icon-192x192.png"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/manifest.json" />
    <link href="https://fonts.cdnfonts.com/css/calorie" rel="stylesheet" />
    <meta name="msapplication-TileColor" content="#ffffff" />
    <meta name="msapplication-TileImage" content="/ms-icon-144x144.png" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="generator" content={Astro.generator} />
    <Seo
      title={title ? `${title} | Dani Akash` : "Dani Akash"}
      description={description ||
        "Empowering ideas and inspiring creativity – Discover more at daniakash.com"}
      keywords={keywords || [
        "Dani Akash",
        "Personal Blog",
        "Tech Blog",
        "Newsletter",
        "Tech Newsletter",
        "Writing",
        "Speaking",
        "Tech Talks",
        "Web Development",
      ]}
      icon="/favicon.ico"
      themeColor="#333333"
      colorScheme="light"
      facebook={ogImage
        ? {
            url: "https://daniakash.com",
            type: "website",
            image: ogImage,
          }
        : {
            url: "https://daniakash.com",
            type: "website",
          }}
      twitter={ogImage
        ? {
            site: "@dani_akash_",
            card: "summary_large_image",
            image: ogImage,
          }
        : {
            site: "@dani_akash_",
            card: "summary",
          }}
    />
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Dani Akash's RSS Feed"
      href={new URL("rss.xml", Astro.site)}
    />
    <ClientRouter />
  </head>
  <body class="flex h-full w-full overflow-x-hidden bg-zinc-50 dark:bg-black">
    <ContentArea />
    <div class="relative m-auto flex w-full max-w-5xl flex-col overflow-visible">
      <div class="px-4 sm:px-6 lg:px-10">
        <Header isHomePage={isHomePage} />
        <main><slot /></main>
        <div class="mt-28 sm:mt-36">
          <Footer />
        </div>
      </div>
    </div>
  </body>
</html>
